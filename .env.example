# Core server config
PORT=3000
HTTPS_ENABLED=false
SSL_CERT_FILE=certs/api.openai.com.pem
SSL_KEY_FILE=certs/api.openai.com-key.pem

# Ollama connection
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Auth: accept any key by default
EXPECTED_API_KEY=
ACCEPT_ANY_API_KEY=true

# Content handling
STRIP_THINK_TAGS=false

# Privileged helper service port
ELEVATOR_PORT=55055