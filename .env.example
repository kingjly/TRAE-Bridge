# Core server config
PORT=30000
HTTPS_ENABLED=false
SSL_CERT_FILE=certs/api.openai.com.pem
SSL_KEY_FILE=certs/api.openai.com-key.pem

# Ollama connection
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Upstream routing (supports Ollama or any OpenAI-compatible API)
# UPSTREAM_TYPE: ollama | openai
UPSTREAM_TYPE=ollama
# Optional. If empty, defaults to OLLAMA_BASE_URL when UPSTREAM_TYPE=ollama
# and https://api.openai.com when UPSTREAM_TYPE=openai.
UPSTREAM_BASE_URL=
# Optional upstream API key (Bearer token). Leave empty to forward incoming Authorization header.
UPSTREAM_API_KEY=
# Optional override paths. Useful for non-standard compatible providers.
UPSTREAM_CHAT_PATH=
UPSTREAM_MODELS_PATH=
# Whether to forward the client's Authorization header when UPSTREAM_API_KEY is empty.
FORWARD_CLIENT_API_KEY=true

# Auth: accept any key by default
EXPECTED_API_KEY=
ACCEPT_ANY_API_KEY=true

# Content handling
STRIP_THINK_TAGS=false

# Privileged helper service port
ELEVATOR_PORT=55055
